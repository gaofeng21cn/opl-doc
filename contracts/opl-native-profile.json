{
  "active_truth_owner": "docs/active/opl-doc-active-truth-plan.md",
  "canonical_docs": [
    {
      "path": "README.md",
      "role": "root_entry"
    },
    {
      "path": "AGENTS.md",
      "role": "repo_agent_working_rules"
    },
    {
      "path": "docs/README.md",
      "role": "docs_entry"
    },
    {
      "path": "docs/project.md",
      "role": "project_positioning"
    },
    {
      "path": "docs/status.md",
      "role": "current_status"
    },
    {
      "path": "docs/architecture.md",
      "role": "architecture_boundary"
    },
    {
      "path": "docs/invariants.md",
      "role": "hard_constraints"
    },
    {
      "path": "docs/decisions.md",
      "role": "active_decision_record"
    }
  ],
  "doc_profile": "codex_plugin",
  "flow_profile": "codex_plugin",
  "machine_truth_surfaces": [
    "contracts",
    "tests",
    "pyproject.toml"
  ],
  "managed_by_plugins": {
    "opl-doc": {
      "authority_boundary": {
        "doctor_role": "lightweight_risk_map_only",
        "does_not_own": [
          "repo_truth",
          "runtime_truth",
          "domain_truth",
          "artifact_authority",
          "quality_verdicts",
          "owner_receipts",
          "production_readiness",
          "foundry_agent_truth_set"
        ],
        "family_plan_role": "workflow_plan_only",
        "native_profile_role": "profile_sync_and_drift_check_only",
        "support_repos_role": "extension_only_not_default_foundry_agent_truth_set"
      },
      "does_not_own": [
        "repo_truth",
        "domain_truth",
        "runtime_truth",
        "artifact_authority",
        "owner_receipts",
        "quality_verdicts",
        "production_readiness"
      ],
      "managed_surfaces": [
        "contracts/opl-native-profile.json"
      ],
      "management": "profile_check_and_sync"
    }
  },
  "owned_by_repo": [
    "contracts/**",
    "src/**",
    "tests/**",
    "docs/status.md",
    "docs/active/opl-doc-active-truth-plan.md"
  ],
  "plugin_native_status": "profile_declared",
  "repo_id": "opl-doc",
  "repo_profile": "codex_plugin",
  "schema": "opl_native_profile.v1",
  "taxonomy_dirs": [
    "docs/active",
    "docs/history"
  ],
  "verification_commands": [
    "scripts/verify.sh",
    "python -m pytest"
  ]
}
